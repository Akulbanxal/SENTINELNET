{
  "name": "sentinelnet-agents",
  "version": "1.0.0",
  "description": "AI agents for SentinelNet verification network",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch trader/index.ts",
    "start": "node dist/trader/index.js",
    "start:trader": "tsx trader/index.ts",
    "start:security": "tsx security-audit/index.ts",
    "start:liquidity": "tsx liquidity-risk/index.ts",
    "start:tokenomics": "tsx tokenomics-analysis/index.ts",
    "start:all": "concurrently \"npm run start:security\" \"npm run start:liquidity\" \"npm run start:tokenomics\" \"npm run start:trader\"",
    "register:agents": "tsx scripts/registerAgents.ts",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.5",
    "dotenv": "^16.3.1",
    "ethers": "^6.9.2",
    "express": "^4.18.2",
    "node-cron": "^3.0.3",
    "openai": "^4.24.1",
    "winston": "^3.11.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.19.37",
    "@types/node-cron": "^3.0.11",
    "@types/ws": "^8.5.10",
    "concurrently": "^9.2.1",
    "jest": "^29.7.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
