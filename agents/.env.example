# ============================================
# SentinelNet Agents Configuration
# ============================================

# ============================================
# Ethereum Network Configuration
# ============================================

# Sepolia Testnet RPC URL
# Get from: https://infura.io or https://alchemy.com
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_PROJECT_ID

# Private key of the wallet for agents (DO NOT COMMIT!)
# This wallet needs Sepolia ETH for gas fees
PRIVATE_KEY=your_private_key_here_without_0x_prefix

# ============================================
# Smart Contract Addresses
# ============================================
# These are deployed by running: cd ../contracts && npm run deploy:all

AGENT_MARKETPLACE_ADDRESS=0x...
AGENT_ESCROW_ADDRESS=0x...
AUDIT_REGISTRY_ADDRESS=0x...
TRADE_EXECUTOR_ADDRESS=0x...

# ============================================
# External API Keys
# ============================================

# OpenAI API Key for AI-powered analysis
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Etherscan API Key for source code verification
# Get from: https://etherscan.io/myapikey
ETHERSCAN_API_KEY=...

# ============================================
# AI Model Configuration
# ============================================

# OpenAI model to use
# Options: gpt-4-turbo-preview, gpt-4, gpt-3.5-turbo
OPENAI_MODEL=gpt-4-turbo-preview

# ============================================
# Logging Configuration
# ============================================

# Log level: debug, info, warn, error
LOG_LEVEL=info

# ============================================
# Demo/Testing Configuration
# ============================================

# Optional: Set a specific token address to analyze in demo mode
# Leave empty to wait for live token discoveries
DEMO_TOKEN_ADDRESS=

# ============================================
# Agent Configuration
# ============================================

# Agent registration fee (in ETH)
AGENT_REGISTRATION_FEE=0.01

# Agent verification price (in ETH)
AGENT_VERIFICATION_PRICE=0.01

# ============================================
# Risk Thresholds (TraderAgent)
# ============================================

# Minimum scores required for trade execution
MIN_OVERALL_SCORE=70
MIN_SECURITY_SCORE=75
MIN_LIQUIDITY_SCORE=65
MIN_TOKENOMICS_SCORE=60

# Require consensus from multiple auditors
REQUIRE_CONSENSUS=true

# ============================================
# DEX Configuration
# ============================================

# Uniswap V2 Factory Address (Sepolia)
UNISWAP_V2_FACTORY=0x7E0987E5b3a30e3f2828572Bb659A548460a3003

# WETH Address (Sepolia)
WETH_ADDRESS=0xfFf9976782d46CC05630D1f6eBAb18b2324d6B14

# ============================================
# Network Configuration
# ============================================

# Chain ID (Sepolia = 11155111)
CHAIN_ID=11155111

# Block confirmation requirement
CONFIRMATIONS=2

# ============================================
# Server Configuration (if running HTTP APIs)
# ============================================

SECURITY_AUDIT_PORT=3001
LIQUIDITY_RISK_PORT=3002
TOKENOMICS_ANALYSIS_PORT=3003
TRADER_AGENT_PORT=3000
